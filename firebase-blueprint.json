{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Service booking details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "address": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["일반 청소", "입주 청소", "이사 청소", "정기 청소"] },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["예약완료", "방문예정", "완료", "취소"] },
        "notes": { "type": "string" },
        "price": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["현장결제", "결제완료"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "userPhone", "address", "serviceType", "date", "time", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer reviews",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "content", "rating"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Storage for user profiles"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Storage for all service bookings"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Storage for customer reviews"
    },
    "/admins/{adminId}": {
      "schema": "object",
      "description": "White-list for admin users (UID as document ID)"
    }
  }
}
